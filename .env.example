# ducklake-in-practice Environment Variables
# Скопируйте в .env и заполните значения

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secret_change_me
POSTGRES_DB=postgres

# DuckLake catalog database
DUCKLAKE_DB=ducklake_catalog
DUCKLAKE_USER=ducklake
DUCKLAKE_PASSWORD=ducklake_secret_change_me

# Airflow metadata database
AIRFLOW_DB=airflow_metadata
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow_secret_change_me

# Superset app database
SUPERSET_DB=superset_appdb
SUPERSET_DB_USER=superset
SUPERSET_DB_PASSWORD=superset_secret_change_me
SUPERSET_SECRET_KEY=superset_secret_change_me_32chars!

# RustFS (S3-compatible)
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin123
RUSTFS_ENDPOINT=http://rustfs:9000
RUSTFS_BUCKET=ducklake-flights

# Airflow
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://${AIRFLOW_DB_USER}:${AIRFLOW_DB_PASSWORD}@postgres:5432/${AIRFLOW_DB}
AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://${AIRFLOW_DB_USER}:${AIRFLOW_DB_PASSWORD}@postgres:5432/${AIRFLOW_DB}
AIRFLOW__WEBSERVER__SECRET_KEY=ducklake_airflow_secret_key_change_me
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=true

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Superset
SUPERSET_CONFIG_PATH=/app/superset_config.py

# Data generation
GEN_FLIGHTS_PER_DAY=800
GEN_BOOKINGS_PER_HOUR=150
GEN_SEED_COUNTRY=Russia
